# Minimal runtime for the openfang daemon under live integration tests.
# Just adds curl + ca-certificates so the compose healthcheck works.
# The binary is mounted from the host at runtime (see docker-compose.tests.yml).
FROM debian:trixie-slim
RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates curl \
    && rm -rf /var/lib/apt/lists/*

# yt-dlp standalone binary (used by youtube-extract and clip hands during
# integration tests).
RUN curl -fsSL https://github.com/yt-dlp/yt-dlp/releases/latest/download/yt-dlp \
        -o /usr/local/bin/yt-dlp \
    && chmod a+rx /usr/local/bin/yt-dlp
